# ── 数据库（本地开发用默认值即可，生产环境务必修改）──
# POSTGRES_PASSWORD=interview123

# ── 管理员邮箱（启动时自动将该邮箱的用户提升为管理员）──
# ADMIN_EMAIL=你的学号@std.uestc.edu.cn

# ── JWT 签名密钥（生产环境务必修改为强随机字符串！）──
# Linux/macOS 生成随机密钥: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# ── SMTP 邮件发送（腾讯企业邮 / 学校邮箱）──
# 配置后验证码将通过邮件真实发送；不配置则仅打印到控制台日志。
SMTP_HOST=smtp.std.uestc.edu.cn
SMTP_PORT=465
SMTP_USER=你的学号@std.uestc.edu.cn
SMTP_PASS=客户端专用密码
