# ── 数据库密码（必填！生产环境务必修改）──
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── JWT 签名密钥（必填！生产环境务必修改）──
# Linux/macOS 生成: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# ── SMTP 邮件发送（腾讯企业邮 / 学校邮箱）──
# 配置后验证码将通过邮件真实发送；不配置则仅打印到控制台日志。
SMTP_HOST=smtp.std.uestc.edu.cn
SMTP_PORT=465
SMTP_USER=你的学号@std.uestc.edu.cn
SMTP_PASS=客户端专用密码
SMTP_TLS_SERVERNAME=icoremail.net
